# configs/tools/esp_idf.env
# ESP-IDF tool profile. Sourced by scripts/env/load_esp.sh.
# Values here override defaults in scripts/common/paths.sh.

IDF_ROOT=/opt/embedded-tools/sdk/esp/esp-idf
IDF_PYTHON_ENV_PATH=${HOME}/.espressif/python_env/idf5.5_py3.10_env

# Default flash parameters (overrideable per project)
IDF_DEFAULT_BAUD=460800
IDF_DEFAULT_PORT_AUTO=1       # 1 = auto-detect, 0 = use IDF_DEFAULT_PORT
IDF_DEFAULT_PORT=/dev/ttyACM0 # used only when IDF_DEFAULT_PORT_AUTO=0

# Monitor
IDF_MONITOR_BAUD=115200
