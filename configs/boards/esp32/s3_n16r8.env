# configs/boards/esp32/s3_n16r8.env
# Board profile: ESP32-S3-WROOM N16R8 with OV3660 camera
#
# N16R8 = 16 MB flash, 8 MB Octal PSRAM
# Camera: OV3660 (Omnivision, 3.6 MP)
# USB-UART: QinHeng CH343P (VID:1a86 PID:55d3) → /dev/ttyACM0 (CDC ACM)
#
# Pin mapping based on ESP32-S3-EYE reference design.
# VERIFY against your board's schematic before flashing.

IDF_TARGET=esp32s3

# Flash / monitor parameters
FLASH_BAUD=460800
MONITOR_BAUD=115200

# Chip and flash info (used by esptool)
ESPTOOL_CHIP=esp32s3
ESPTOOL_FLASH_SIZE=16MB
ESPTOOL_FLASH_MODE=dio
ESPTOOL_FLASH_FREQ=80m

# Camera chip
BOARD_CAMERA_MODEL=OV3660
BOARD_CAMERA_XCLK_MHZ=20

# PSRAM type for sdkconfig
# N16R8 uses Octal (OPI) PSRAM
BOARD_PSRAM_TYPE=octal
BOARD_PSRAM_SIZE_MB=8
